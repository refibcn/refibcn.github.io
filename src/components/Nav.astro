---
import fs from "node:fs";
import path from "node:path";
import yaml from "js-yaml";
const site = yaml.load(
  fs.readFileSync(path.join(process.cwd(), "src/data/site.yaml"), "utf8")
) as { name: string };

interface Props {
  current?: string;
  section?: string;
  dataset?: string;
}
const { current = "home", section, dataset } = Astro.props;
const items = [
  { id: "what-we-do", label: "What we do", href: "/what-we-do/" },
  { id: "who-we-serve", label: "Who we serve", href: "/who-we-serve/" },
  { id: "projects", label: "Projects", href: "/projects/" },
  { id: "atlas", label: "Atlas", href: "/atlas/" },
  { id: "commons", label: "Commons", href: "/commons/" },
  { id: "about", label: "About", href: "/about/" },
];
---
<header class="site-nav">
  <a href="/" class="brand" aria-label={`${site.name} — home`}>
    <span class="brand-org">{site.name}</span>
    {section && <><span class="brand-sep">·</span><span class="brand-system">{section}</span></>}
    {dataset && <><span class="brand-sep">·</span><span class="brand-dataset">{dataset}</span></>}
  </a>
  <nav aria-label="Primary">
    <ul>
      {items.map((it) => (
        <li><a href={it.href} class:list={[{ active: current === it.id }]}>{it.label}</a></li>
      ))}
      <li><a href="/contact/" class:list={["nav-cta", { active: current === "contact" }]}>Contact</a></li>
    </ul>
  </nav>
</header>
<style>
.site-nav { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1rem var(--gutter); border-bottom: 1px solid var(--ink); background: var(--paper); position: sticky; top: 0; z-index: 10; }
.brand { display: flex; align-items: baseline; gap: 0.6rem; text-decoration: none; color: var(--ink); font-family: var(--mono); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em; }
.brand-org { font-weight: 500; }
.brand-system, .brand-sep { color: var(--rule); }
.brand-dataset { color: var(--ink); }
nav ul { list-style: none; display: flex; gap: 1.25rem; margin: 0; padding: 0; flex-wrap: wrap; }
nav a { font-family: var(--mono); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--rule); text-decoration: none; padding: 0.25rem 0; border-bottom: 1px solid transparent; white-space: nowrap; }
nav a.active, nav a:hover { color: var(--ink); border-bottom-color: var(--ink); }
nav a.nav-cta {
  color: var(--primary-foreground);
  background: var(--primary);
  border: 1px solid var(--primary);
  padding: 0.3rem 0.75rem;
  transition: background-color var(--t-fast), border-color var(--t-fast);
}
nav a.nav-cta:hover, nav a.nav-cta.active { background: var(--primary-hover); border-color: var(--primary-hover); color: var(--primary-foreground); }
@media (max-width: 880px) { .brand-system, .brand-sep { display: none; } }
@media (max-width: 720px) { .site-nav { flex-direction: column; align-items: flex-start; } nav ul { gap: 0.9rem; } }
</style>
