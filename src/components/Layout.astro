---
import "@fontsource-variable/fraunces";
import "@fontsource-variable/inter";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";
import "@fontsource/averia-serif-libre/400.css";
import "@fontsource/averia-serif-libre/700.css";
import "../styles/tokens.css";
import "../styles/theme.css";
import "../styles/global.css";
import Nav from "./Nav.astro";
import Footer from "./Footer.astro";
import fs from "node:fs";
import path from "node:path";
import yaml from "js-yaml";

const site = yaml.load(
  fs.readFileSync(path.join(process.cwd(), "src/data/site.yaml"), "utf8")
) as { name: string; url: string; description: string; ogImage: string };

interface Props {
  title: string;
  description?: string;
  current?: "home" | "what-we-do" | "who-we-serve" | "projects" | "atlas" | "commons" | "about" | "contact";
  section?: string;     // optional contextual brand-line segment (e.g. "Bioregional Commons")
  dataset?: string;     // e.g. "Catalunya"
  minimal?: boolean;
  noindex?: boolean;
}
const {
  title,
  description = site.description,
  current = "home", section, dataset, minimal = false, noindex = false,
} = Astro.props;
const pageTitle = `${title} · ${site.name}`;
// i18n: CA/ES currently serve EN via rewrite fallback (untranslated). Point
// canonical at the EN page and noindex the locale duplicates until real
// translations land, so search engines index one copy.
const loc = Astro.currentLocale ?? "en";
const logicalPath = Astro.url.pathname.replace(/^\/(ca|es)(?=\/|$)/, "") || "/";
const canonical = new URL(loc === "en" ? Astro.url.pathname : logicalPath, site.url).href;
const localeFallbackNoindex = loc !== "en";
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  {(noindex || localeFallbackNoindex) && <meta name="robots" content="noindex" />}
  <title>{pageTitle}</title>
  <link rel="icon" type="image/png" href="/assets/favicons.png" />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={site.name} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={new URL(site.ogImage, site.url).href} />
  <meta name="twitter:card" content="summary_large_image" />
</head>
<body class:list={{ minimal }}>
  {!minimal && <Nav current={current} section={section} dataset={dataset} />}
  <main><slot /></main>
  {!minimal && <Footer />}
  <script>
    // Section reveal (iteration 4). Classes are added here, so no-JS
    // visitors get plain static rendering; reduced-motion users get 0ms
    // transitions via the motion tokens.
    const els = document.querySelectorAll("main > section, main > header, main > article");
    if ("IntersectionObserver" in window && els.length) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("reveal--in");
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.08 },
      );
      els.forEach((el) => {
        el.classList.add("reveal");
        io.observe(el);
      });
    }
  </script>
</body>
</html>
