---
// FlowDivider.astro — soft river/flow section divider (DESIGN.md §5, Flows).
// Decorative inline SVG, zero client-JS.
interface Props {
  flip?: boolean;
  tone?: string;   // CSS var for stroke
}
const { flip = false, tone = "--pillar-flow-mid" } = Astro.props;
---
<div class={`flow-divider${flip ? " flow-divider--flip" : ""}`} aria-hidden="true">
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" width="100%" height="60">
    <path d="M0,30 C240,5 480,55 720,30 C960,5 1200,55 1440,30"
          fill="none" stroke={`var(${tone})`} stroke-width="2" opacity="0.5" />
    <path d="M0,42 C240,18 480,66 720,42 C960,18 1200,66 1440,42"
          fill="none" stroke={`var(${tone})`} stroke-width="1.25" opacity="0.28" />
  </svg>
</div>
<style>
.flow-divider { line-height: 0; width: 100%; }
.flow-divider--flip { transform: scaleY(-1); }
</style>
