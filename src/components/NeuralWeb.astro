---
// NeuralWeb.astro — seeded node/edge network (DESIGN.md §5, Neural Networks).
// Build-time deterministic (mulberry32 RNG — no nondeterministic Math.random).
// Zero client-JS. Also the data-viz hook for future BIS map embedding.
interface Props {
  seed?: number;
  nodes?: number;
  tone?: string;       // node/edge color var
  width?: number;
  height?: number;
}
const { seed = 7, nodes = 16, tone = "--pillar-neural-mid", width = 640, height = 480 } = Astro.props;

function mulberry32(a: number) {
  return function () {
    a |= 0; a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rng = mulberry32(seed);
const pts = Array.from({ length: nodes }, () => ({
  x: Math.round(20 + rng() * (width - 40)),
  y: Math.round(20 + rng() * (height - 40)),
  r: 2 + Math.round(rng() * 4),
}));
// connect each node to its 2 nearest neighbours
const edges: [number, number][] = [];
pts.forEach((p, i) => {
  const near = pts
    .map((q, j) => ({ j, d: (q.x - p.x) ** 2 + (q.y - p.y) ** 2 }))
    .filter((o) => o.j !== i)
    .sort((a, b) => a.d - b.d)
    .slice(0, 2);
  near.forEach((o) => { if (i < o.j) edges.push([i, o.j]); });
});
---
<svg class="neural-web" viewBox={`0 0 ${width} ${height}`} role="img" aria-label="Network of interconnected nodes">
  {edges.map(([a, b]) => (
    <line x1={pts[a].x} y1={pts[a].y} x2={pts[b].x} y2={pts[b].y}
          stroke={`var(${tone})`} stroke-width="1" opacity="0.35" />
  ))}
  {pts.map((p) => (
    <circle cx={p.x} cy={p.y} r={p.r} fill={`var(${tone})`} opacity="0.8" />
  ))}
</svg>
<style>
.neural-web { width: 100%; height: auto; display: block; }
</style>
