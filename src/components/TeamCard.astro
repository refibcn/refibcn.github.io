---
// TeamCard.astro — editorial member tile. No portrait photos exist, so the
// visual anchor is an Averia monogram over a pillar-tinted aurora header.
import Aurora from "./Aurora.astro";

interface Props {
  name: string;
  role: string;
  bio?: string;
  pillar?: "neural" | "tissue" | "flow";
}
const { name, role, bio, pillar = "tissue" } = Astro.props;
const initials = name.split(/\s+/).slice(0, 2).map((w) => w[0]).join("");
---
<article class="team-card">
  <div class="team-card__visual">
    <Aurora pillar={pillar} opacity={0.7} />
    <span class="team-card__monogram" aria-hidden="true">{initials}</span>
  </div>
  <h3 class="team-card__name">{name}</h3>
  <p class="team-card__role eyebrow">{role}</p>
  {bio && <p class="team-card__bio">{bio}</p>}
</article>

<style>
.team-card {
  border: 1px solid var(--ink, var(--border-default));
  background: var(--bg);
  display: flex;
  flex-direction: column;
}
.team-card__visual {
  position: relative;
  isolation: isolate;
  overflow: hidden;
  aspect-ratio: 21 / 9;
  border-bottom: 1px solid var(--ink, var(--border-default));
  display: grid;
  place-items: center;
}
.team-card__monogram {
  position: relative;
  z-index: 1;
  font-family: var(--serif);
  font-size: var(--text-3xl);
  line-height: 1;
  color: var(--text-primary);
  opacity: 0.85;
}
.team-card__name { font-size: var(--text-lg); margin: var(--space-5) var(--space-5) var(--space-1); }
.team-card__role { margin: 0 var(--space-5) var(--space-3); }
.team-card__bio {
  color: var(--text-muted);
  font-size: var(--text-sm);
  line-height: var(--leading-body);
  margin: 0 var(--space-5) var(--space-5);
}
</style>
