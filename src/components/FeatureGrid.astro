---
// FeatureGrid.astro — featured-first project layout shared by the landing
// and /projects (plan iteration 4). The first item renders large (image +
// text side by side); the rest fall into a compact auto-fit grid. Cards
// without an image get a pillar-tinted aurora placeholder instead of a gap,
// so the grid stays visually even. Theme-pure — vars only, no raw hex.
import PillarBadge from "./PillarBadge.astro";
import Aurora from "./Aurora.astro";

interface Item {
  heading?: string;      // editorial one-liner (landing voice)
  name: string;          // project name
  excerpt: string;
  image?: string;
  href: string;
  external?: boolean;
  pillars?: string[];
}
interface Props { items: Item[]; featuredCount?: number; }
const { items, featuredCount = 1 } = Astro.props;

const featured = items.slice(0, featuredCount);
const rest = items.slice(featuredCount);
const linkLabel = (it: Item) => (it.external ? "Visit site ↗" : "Read case study →");
const linkAttrs = (it: Item) =>
  it.external ? { target: "_blank", rel: "noopener" } : {};
---
<div class="feature-grid">
  {featured.map((it) => (
    <article class="feat feat--lg">
      <div class="feat__media">
        {it.image
          ? <img class="feat__img" src={it.image} alt="" loading="lazy" />
          : <Aurora pillar={(it.pillars?.[0] as any) ?? "tissue"} opacity={0.6} />}
      </div>
      <div class="feat__body">
        {it.pillars && <div class="feat__badges">{it.pillars.map((k) => <PillarBadge pillar={k as any} />)}</div>}
        {it.heading && <h3 class="feat__heading">{it.heading}</h3>}
        <p class="feat__name">{it.name}</p>
        <p class="feat__excerpt">{it.excerpt}</p>
        <a class="feat__link" href={it.href} {...linkAttrs(it)}>{linkLabel(it)}</a>
      </div>
    </article>
  ))}

  {rest.length > 0 && (
    <div class="feature-grid__rest">
      {rest.map((it) => (
        <article class="feat feat--sm">
          <div class="feat__media feat__media--sm">
            {it.image
              ? <img class="feat__img" src={it.image} alt="" loading="lazy" />
              : <Aurora pillar={(it.pillars?.[0] as any) ?? "neural"} opacity={0.55} />}
          </div>
          <div class="feat__body">
            {it.pillars && <div class="feat__badges">{it.pillars.map((k) => <PillarBadge pillar={k as any} />)}</div>}
            {it.heading && <h3 class="feat__heading">{it.heading}</h3>}
            <p class="feat__name">{it.name}</p>
            <p class="feat__excerpt">{it.excerpt}</p>
            <a class="feat__link" href={it.href} {...linkAttrs(it)}>{linkLabel(it)}</a>
          </div>
        </article>
      ))}
    </div>
  )}
</div>

<style>
.feature-grid { display: flex; flex-direction: column; gap: var(--space-5); }

.feat {
  background: var(--bg);
  border: 1px solid var(--ink);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: translate var(--t-med), box-shadow var(--t-med);
}
.feat:hover {
  translate: 0 -2px;
  box-shadow: 4px 4px 0 color-mix(in srgb, var(--ink) 12%, transparent);
}
.feat__media { position: relative; isolation: isolate; overflow: hidden; }
.feat__img { width: 100%; height: 100%; object-fit: cover; }
.feat__body { padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-3); flex: 1; }
.feat__badges { display: flex; gap: var(--space-2); flex-wrap: wrap; }
.feat__heading { font-size: var(--text-lg); margin: 0; }
.feat__name { font-family: var(--mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin: 0; }
.feat__excerpt { color: var(--text-muted); line-height: var(--leading-body); font-size: var(--text-sm); margin: 0; flex: 1; }
.feat__link { font-family: var(--mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.06em; color: var(--primary); text-decoration: none; margin-top: auto; }
.feat__link:hover { text-decoration: underline; }

/* Featured: image left, content right on wide screens */
.feat--lg { display: grid; grid-template-columns: 1.1fr 1fr; }
.feat--lg .feat__media { min-height: 22rem; border-right: 1px solid var(--ink); }
.feat--lg .feat__media .aurora { position: absolute; inset: 0; }
.feat--lg .feat__heading { font-size: var(--text-xl); }
.feat--lg .feat__body { padding: var(--space-8); justify-content: center; }

/* Compact grid */
.feature-grid__rest { display: grid; grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr)); gap: var(--space-5); }
.feat--sm .feat__media--sm { aspect-ratio: 16 / 9; border-bottom: 1px solid var(--ink); }

@media (max-width: 820px) {
  .feat--lg { grid-template-columns: 1fr; }
  .feat--lg .feat__media { min-height: 0; aspect-ratio: 16 / 9; border-right: 0; border-bottom: 1px solid var(--ink); }
}
</style>
