---
// src/components/NetworkSection.astro
import ProjectCard from "./ProjectCard.astro";
import type { Project, NetworkMeta } from "../content.config";

interface Props {
  networkId: "miceli" | "keras-buti";
  meta: NetworkMeta;
  projects: Project[];
}
const { networkId, meta, projects } = Astro.props;
const fmt = new Intl.NumberFormat("en-US", { style: "currency", currency: "EUR", maximumFractionDigits: 0 });
---

<section class="network" data-network={networkId}>
  <header class="network-header">
    <p class="eyebrow">Network</p>
    <h2>{meta.name}</h2>
    <div class="meta-row">
      <span class="role">{meta.role}</span>
      <span class="contribution">Matching pool · {fmt.format(meta.contribution_eur)}</span>
      <span class="count">{projects.length} project{projects.length === 1 ? "" : "s"}</span>
    </div>
    <p class="summary">{meta.summary}</p>
  </header>

  <div class="grid">
    {projects.map((p) => <ProjectCard project={p} networkMeta={meta} />)}
  </div>
</section>

<style>
.network {
  padding: 3rem 2rem;
  border-top: 1px solid var(--ink);
}
.network-header {
  max-width: 60rem;
  margin: 0 auto 2rem;
}
.network-header h2 {
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  margin: 0.25rem 0 0.5rem;
}
.meta-row {
  display: flex;
  gap: 1.5rem;
  flex-wrap: wrap;
  font-family: var(--mono);
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--rule);
  margin-bottom: 1rem;
}
.network-header .summary {
  font-family: var(--serif);
  font-size: 1.05rem;
  color: var(--ink);
  max-width: 50ch;
}
.grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1.5rem;
  max-width: 80rem;
  margin: 0 auto;
}
@media (max-width: 1024px) {
  .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
@media (max-width: 640px) {
  .grid { grid-template-columns: 1fr; }
}
</style>
