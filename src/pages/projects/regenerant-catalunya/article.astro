---
// src/pages/projects/regenerant-catalunya/article.astro
// Article-companion view of the Regenerant Catalunya program. Same chrome and
// editorial aesthetic as the dashboard view, but the map is the centerpiece —
// full-width, taller, and clicking a marker pops up the project card inline.
import Layout from "../../../components/Layout.astro";
import NetworkSection from "../../../components/NetworkSection.astro";
import CatalunyaProgramMap from "../../../components/CatalunyaProgramMap.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("cohort");
const doc = entries[0]!.data;
const miceli = doc.projects.filter((p) => p.network === "miceli");
const kerasButi = doc.projects.filter((p) => p.network === "keras-buti");
const fmt = new Intl.NumberFormat("en-US", { style: "currency", currency: "EUR", maximumFractionDigits: 0 });
const totalMatching = doc.networks.miceli.contribution_eur + doc.networks["keras-buti"].contribution_eur;
---

<Layout title="Regenerant Catalunya · Article view" current="projects" dataset="Regenerant Catalunya">
  <section class="hero">
    <p class="eyebrow">Program · 2025–2026 · GG24 · article companion</p>
    <h1>Regenerant Catalunya</h1>
    <p class="lede">
      11 projects · 2 networks · {fmt.format(totalMatching)} matching pool · funded through Gitcoin Grants Round 24.
    </p>
    <p class="prose">
      Regenerant Catalunya unites a diverse cohort of regenerative initiatives across Catalonia under one
      funding umbrella. Projects were scouted by two trusted local networks — <strong>Miceli Social</strong>
      (rural) and <strong>La Fundició / Keras Buti</strong> (urban) — and back a broad definition of regeneration
      that spans ecological restoration, community projects, and civic innovation.
    </p>
    <div class="cta-row">
      <a href="https://regenerant-catalunya.refibcn.cat">↗ Regenerant Catalunya site</a>
      <a href="/projects/regenerant-catalunya/" class="ghost">↗ Dashboard view</a>
    </div>
  </section>

  <section class="map-section">
    <div class="map-frame">
      <CatalunyaProgramMap projects={doc.projects} networks={doc.networks} />
    </div>
    <div class="map-meta">
      <article class="net-tile" data-accent="forest">
        <p class="eyebrow">Rural network · Miceli Social</p>
        <p>{fmt.format(doc.networks.miceli.contribution_eur)} matching pool · {miceli.length} projects · Ripoll-anchored, dispersed across rural comarques.</p>
      </article>
      <article class="net-tile" data-accent="rust">
        <p class="eyebrow">Urban network · La Fundició / Keras Buti</p>
        <p>{fmt.format(doc.networks["keras-buti"].contribution_eur)} matching pool · {kerasButi.length} projects · L'Hospitalet de Llobregat metro cluster.</p>
      </article>
    </div>
  </section>

  <NetworkSection networkId="miceli" meta={doc.networks.miceli} projects={miceli} />
  <NetworkSection networkId="keras-buti" meta={doc.networks["keras-buti"]} projects={kerasButi} />

  <section class="cohort-footer">
    <div class="pending">
      <p class="eyebrow">Pending cohort · TBC</p>
      <ul>
        {doc.pending.map((p) => <li>{p.name}</li>)}
      </ul>
    </div>
    <div class="funders">
      <p class="eyebrow">Funders</p>
      <ul>
        {doc.funders.map((f) => (
          <li><a href={f.web}>{f.name}</a> · <span>{f.role}</span></li>
        ))}
      </ul>
    </div>
  </section>
</Layout>

<style>
.hero {
  max-width: 60rem;
  margin: 0 auto;
  padding: 4rem 2rem 2rem;
}
.hero h1 { margin: 0.25rem 0 0.5rem; }
.hero .lede {
  font-family: var(--mono);
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--rule);
  margin-bottom: 1.5rem;
}
.hero .prose {
  font-family: var(--serif);
  font-size: 1.1rem;
  max-width: 50ch;
  margin: 0 0 1rem;
}
.cta-row {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-top: 1rem;
}
.cta-row a {
  font-family: var(--mono);
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  text-decoration: none;
  border: 1px solid var(--ink);
  padding: 0.4rem 0.8rem;
  color: var(--ink);
  transition: background var(--t-fast);
}
.cta-row a:hover { background: var(--ink); color: var(--paper); }
.cta-row a.ghost {
  border-color: var(--rule);
  color: var(--rule);
}
.cta-row a.ghost:hover {
  border-color: var(--ink);
  background: var(--ivory);
  color: var(--ink);
}

.map-section {
  background: var(--ivory);
  border-top: 1px solid var(--ink);
  border-bottom: 1px solid var(--ink);
  padding: 2rem;
}
.map-frame {
  max-width: 100rem;
  margin: 0 auto;
}
.map-meta {
  max-width: 80rem;
  margin: 1.5rem auto 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}
@media (max-width: 720px) {
  .map-meta { grid-template-columns: 1fr; }
}
.net-tile {
  border: 1px solid var(--ink);
  background: var(--paper);
  padding: 0.9rem 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}
.net-tile p { margin: 0; font-family: var(--serif); font-size: 0.95rem; }
.net-tile .eyebrow {
  font-family: var(--mono);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin: 0;
}
.net-tile[data-accent="forest"] .eyebrow { color: var(--forest); }
.net-tile[data-accent="rust"] .eyebrow { color: var(--rust); }

.cohort-footer {
  padding: 3rem 2rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  max-width: 80rem;
  margin: 0 auto;
}
@media (max-width: 640px) {
  .cohort-footer { grid-template-columns: 1fr; }
}
.cohort-footer ul {
  list-style: none;
  padding: 0;
  margin: 0.5rem 0 0;
  font-family: var(--serif);
}
.cohort-footer li { margin-bottom: 0.4rem; }
.cohort-footer a { color: var(--ink); }
</style>
