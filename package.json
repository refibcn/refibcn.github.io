{
  "name": "refibcn-site",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "ReFi BCN — the new coop website (refibcn.cat). Consolidated Astro site: marketing + Atlas (maps) + Bioregional Commons. Built on the BIS editorial shell with Andrea's organic atmosphere.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/verify-public-kb.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "test": "node --test tests/*.test.mjs",
    "protect:commons": "node scripts/protect-commons-review.mjs",
    "verify:commons": "node scripts/verify-commons-protected.mjs",
    "build:commons-protected": "COMMONS_REVIEW=1 astro build && npm run protect:commons && npm run verify:commons"
  },
  "dependencies": {
    "astro": "^5.0.0",
    "d3": "^7.9.0",
    "maplibre-gl": "^5.24.0"
  },
  "devDependencies": {
    "staticrypt": "^3.5.0",
    "@fontsource-variable/fraunces": "^5.0.0",
    "@fontsource-variable/inter": "^5.0.0",
    "@fontsource/ibm-plex-mono": "^5.0.0",
    "@fontsource-variable/geist": "^5.0.0",
    "@fontsource-variable/geist-mono": "^5.0.0",
    "@fontsource/averia-serif-libre": "^5.0.0",
    "js-yaml": "^4.1.1",
    "@types/js-yaml": "^4.0.9",
    "@types/d3": "^7.4.3"
  }
}
