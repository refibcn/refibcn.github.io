---
interface Props { href: string; eyebrow?: string; title: string; body?: string; status?: string; }
const { href, eyebrow, title, body, status } = Astro.props;
---
<a class="tile" href={href}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2 class="tile__title">{title}</h2>
  {body && <p class="tile__body">{body}</p>}
  {status && <span class="tile__status">{status}</span>}
</a>
<style>
.tile { background: var(--paper); padding: var(--space-8) var(--space-6); text-decoration: none; color: var(--text-primary); display: flex; flex-direction: column; gap: var(--space-2); transition: background var(--t-fast); }
.tile:hover { background: var(--ivory); }
.tile__title { margin: var(--space-1) 0 0; }
.tile__body { flex: 1; color: var(--text-muted); font-family: var(--serif); }
.tile__status { font-family: var(--mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink); border-top: 1px dashed var(--rule); padding-top: var(--space-2); margin-top: var(--space-2); }
</style>
