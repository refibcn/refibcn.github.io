---
import NeuralWeb from "./NeuralWeb.astro";
import Tissue from "./Tissue.astro";
interface Props {
  title: string;
  tagline?: string;
  primaryCta?: { label: string; href: string };
  ghostCta?: { label: string; href: string };
  image?: string;
  neural?: boolean;
  tissue?: boolean;
}
const { title, tagline, primaryCta, ghostCta, image, neural = false, tissue = false } = Astro.props;
---

<section class="hero">
  {tissue && <Tissue seed={3} opacity={0.06} tone="--pillar-tissue-mid" />}
  <div class="hero__copy">
    <h1 class="hero__title display">{title}</h1>
    {tagline && <p class="hero__tagline">{tagline}</p>}
    <div class="hero__actions">
      {primaryCta && <a class="btn btn--primary" href={primaryCta.href}>{primaryCta.label}</a>}
      {ghostCta && <a class="btn btn--ghost" href={ghostCta.href}>{ghostCta.label}</a>}
    </div>
  </div>
  {(neural || image) && (
    <div class="hero__visual">
      {neural
        ? <div class="hero__neural"><NeuralWeb seed={11} nodes={22} tone="--pillar-neural-mid" width={560} height={460} /></div>
        : <img src={image} alt="" />}
    </div>
  )}
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--space-20) var(--gutter);
    max-width: var(--container-wide);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  .hero > :not(.tissue) { position: relative; z-index: 1; }
  .hero__title {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: var(--leading-display);
    font-weight: var(--font-display-weight, 400);
    margin-bottom: var(--space-5);
  }
  .hero__tagline {
    font-size: var(--text-md);
    color: var(--text-muted);
    margin-bottom: var(--space-8);
    max-width: 42ch;
    line-height: var(--leading-body);
  }
  .hero__actions { display: flex; gap: var(--space-3); flex-wrap: wrap; }
  .hero__visual img { width: 100%; border-radius: var(--radius); }
  .hero__neural {
    background: var(--surface-1);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius);
    padding: var(--space-6);
  }
  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; }
    .hero__visual { order: -1; }
  }
</style>
