---
import Layout from "../components/Layout.astro";
import SectionBlock from "../components/SectionBlock.astro";
---
<Layout title="Commons" current="commons" section="Bioregional Commons"
  description="The bioregional knowledge commons — a shared, reusable knowledge base for Catalunya's regenerative ecosystem.">
  <SectionBlock id="commons" title="Bioregional Commons" intro="A shared, reusable knowledge base for the territory's regenerative ecosystem — actors, practices, and resources gathered into a commons rather than scattered." tissue={true} tissueSeed={4}>
    <p class="lede">The knowledge commons consolidates the organization's knowledge into one legible, maintainable surface. Content migration follows the host-architecture decision; the structure lives here.</p>
    <p><span class="badge badge--info">In development</span></p>
  </SectionBlock>
</Layout>
