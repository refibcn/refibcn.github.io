---
import Layout from "../components/Layout.astro";
import SectionBlock from "../components/SectionBlock.astro";
import Button from "../components/Button.astro";
import Tissue from "../components/Tissue.astro";
import FlowDivider from "../components/FlowDivider.astro";
import NeuralWeb from "../components/NeuralWeb.astro";

const neutrals = ["--paper-50", "--paper-100", "--paper-200", "--paper-700", "--paper-900"];
const neural = ["--pillar-neural-1", "--pillar-neural-2", "--pillar-neural-3", "--pillar-neural-4", "--pillar-neural-5", "--pillar-neural-6"];
const tissue = ["--pillar-tissue-1", "--pillar-tissue-2", "--pillar-tissue-3", "--pillar-tissue-4", "--pillar-tissue-5", "--pillar-tissue-6"];
const flow = ["--pillar-flow-1", "--pillar-flow-2", "--pillar-flow-3", "--pillar-flow-4", "--pillar-flow-5", "--pillar-flow-6"];
const library = ["--lib-coral", "--lib-amber", "--lib-sky", "--lib-rose", "--lib-slate", "--lib-teal", "--lib-gold", "--lib-indigo", "--lib-moss"];
---

<Layout title="Lab — internal" current="home" noindex={true} description="Internal element + branding test surface.">
  <SectionBlock title="Lab" intro="Internal element + branding test surface. Renders the ACTIVE theme (editorial-organic). Flip src/styles/theme.css to compare organic / brand-family. Palette, type, motifs, and primitives below.">
    <p class="eyebrow" style="margin-bottom: var(--space-8);">Internal — not linked in nav, noindex</p>

    <div class="note">
      <strong>Dual-theme architecture.</strong> The active direction is <code>organic</code>
      (Andrea's three-pillar lock). Flip the whole site to the v2 <code>brand-family</code>
      palette by editing the single <code>@import</code> in <code>src/styles/theme.css</code>.
      Everything below re-renders from that one line.
    </div>

    <h2>1. Color — paper neutrals</h2>
    <div class="swatches">{neutrals.map((t) => (<div class="swatch" style={`background: var(${t})`}><code>{t}</code></div>))}</div>

    <h2>2. Pillars</h2>
    <p class="eyebrow">Neural · networks</p>
    <div class="swatches">{neural.map((t) => (<div class="swatch" style={`background: var(${t})`}><code>{t}</code></div>))}</div>
    <p class="eyebrow">Tissue · cells</p>
    <div class="swatches">{tissue.map((t) => (<div class="swatch" style={`background: var(${t})`}><code>{t}</code></div>))}</div>
    <p class="eyebrow">Flow · rivers</p>
    <div class="swatches">{flow.map((t) => (<div class="swatch" style={`background: var(${t})`}><code>{t}</code></div>))}</div>

    <h2 style="margin-top: var(--space-12);">3. Library accents (data-viz / status)</h2>
    <div class="swatches">{library.map((t) => (<div class="swatch" style={`background: var(${t})`}><code>{t}</code></div>))}</div>

    <h2 style="margin-top: var(--space-12);">4. Typography <span style="font-family: var(--mono); font-size: var(--text-sm); color: var(--text-muted); text-transform: none;">(fonts follow the active theme — editorial-organic = Averia Serif Libre · Inter · IBM Plex Mono)</span></h2>
    <p class="display" style="font-size: var(--text-5xl); margin: 0;">Display — serif</p>
    <h2 style="margin: var(--space-4) 0 0;">Headings — serif</h2>
    <h3 style="margin: var(--space-2) 0 0;">Subsection — serif</h3>
    <p>Body text — sans, the default reading size. Multi-line shows the line-height used for readability across longer passages.</p>
    <p class="eyebrow">Eyebrow pattern (mono caps + 0.1em tracking)</p>
    <p style="font-family: var(--mono); font-size: var(--text-sm);">code · multisig 0x6D18…dD2D · for code + addresses</p>

    <h2 style="margin-top: var(--space-12);">5. Motifs</h2>
    <p class="eyebrow">Tissue · organic cell texture</p>
    <div class="motif-row">
      <div class="motif-box"><Tissue seed={1} opacity={0.4} tone="--pillar-tissue-mid" /></div>
      <div class="motif-box"><Tissue seed={2} opacity={0.4} tone="--pillar-neural-mid" /></div>
      <div class="motif-box"><Tissue seed={3} opacity={0.4} tone="--pillar-flow-mid" /></div>
    </div>
    <p class="eyebrow" style="margin-top: var(--space-6);">Flow · section divider</p>
    <FlowDivider />
    <p class="eyebrow" style="margin-top: var(--space-6);">Neural · network treatment</p>
    <div class="motif-box motif-box--neural"><NeuralWeb seed={11} nodes={20} tone="--pillar-neural-mid" /></div>

    <h2 style="margin-top: var(--space-12);">6. Primitives</h2>
    <h3>Buttons</h3>
    <div style="display: flex; gap: var(--space-3); flex-wrap: wrap;">
      <Button variant="primary">Primary</Button>
      <Button variant="secondary">Secondary</Button>
      <Button variant="ghost">Ghost</Button>
    </div>
    <h3 style="margin-top: var(--space-6);">Cards</h3>
    <div class="card-grid">
      <article class="card">
        <div class="card__body">
          <h4 class="card__title">Card title</h4>
          <p class="card__text">Body copy explaining the card.</p>
          <a class="card__action" href="/projects">Learn more →</a>
        </div>
      </article>
    </div>
    <h3 style="margin-top: var(--space-6);">Links</h3>
    <p>Inline link: <a class="link" href="/what-we-do">our services</a>. External: <a class="link link--external" href="https://refidao.com/" target="_blank" rel="noopener">ReFi DAO site</a>.</p>
    <h3 style="margin-top: var(--space-6);">Badges</h3>
    <div style="display: flex; gap: var(--space-2); flex-wrap: wrap;">
      <span class="badge">Default</span>
      <span class="badge badge--success">Active</span>
      <span class="badge badge--warning">Pending</span>
      <span class="badge badge--danger">Failed</span>
      <span class="badge badge--info">Info</span>
    </div>
  </SectionBlock>
</Layout>

<style>
  .note {
    background: var(--surface-1);
    border: 1px solid var(--border-subtle);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    padding: var(--space-4) var(--space-5);
    margin-bottom: var(--space-10);
    max-width: 70ch;
    line-height: var(--leading-body);
  }
  .swatches {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }
  .swatch {
    aspect-ratio: 4 / 3;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    padding: var(--space-2);
    display: flex;
    align-items: flex-end;
  }
  .swatch code {
    font-family: var(--mono);
    font-size: var(--text-xs);
    background: var(--bg);
    color: var(--text-primary);
    padding: 2px 4px;
    border-radius: var(--radius-sm);
  }
  .motif-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-4);
  }
  .motif-box {
    position: relative;
    isolation: isolate;
    height: 160px;
    background: var(--surface-1);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .motif-box--neural {
    height: auto;
    max-width: 520px;
    padding: var(--space-6);
  }
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
  }
</style>
