---
// Commons review surface — password-gated INTERNAL KB application (Phase 3.0a → KB-app v2).
// Fully self-contained on purpose: every byte of KB-derived content stays in this one
// HTML file so staticrypt encrypts all of it (no /_astro assets, no bundled data chunks).
// Styling mirrors editorial-organic.css values inline for the same reason.
import { loadKb, facets, graphData, connections } from "../lib/kb.mjs";
import { COLORS, TYPE_INFO } from "../lib/kb-render.mjs";

// Data only exists in the INTERNAL build (the encrypted bucket). A plain
// `astro build` renders a stub so a public site deploy can never ship the
// raw dataset (env gate = belt; verify-public-kb canary scan = braces).
const INTERNAL = process.env.COMMONS_REVIEW === "1";
const objects = INTERNAL ? loadKb() : [];
const { schemas, domains, highRisk } = facets(objects);
const graph = graphData(objects);
const conn = connections(objects);
const bySchema = Object.fromEntries(schemas.map((s) => [s, objects.filter((o) => o.schema === s).length]));
const rawCount = objects.filter((o) => o.maturity === "raw").length;

const inlineJson = (v) => JSON.stringify(v).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>ReFi BCN — internal review</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style is:inline>
      :root {
        --paper: #fbf9f3; --ivory: #f6f1e8; --sand: #ece4d8;
        --ink: #1d1a16; --mut: #6b6660; --rule: #d9d0c2;
        --red: #C92637; --blue: #426EAF; --amber: #B08000;
        --radius: 8px; --t: 120ms ease; --sidebar: 274px;
        --font-display: "Fraunces", Georgia, serif;
        --font-body: "Inter", system-ui, -apple-system, sans-serif;
        --font-mono: "IBM Plex Mono", ui-monospace, monospace;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; height: 100%; }
      body { background: var(--paper); color: var(--ink); font: 15px/1.55 var(--font-body); }
      a { color: var(--blue); }
      .app { display: flex; min-height: 100dvh; }

      /* ── Sidebar ────────────────────────────────────── */
      aside.side {
        width: var(--sidebar); flex: none; border-right: 1px solid var(--sand);
        background: var(--ivory); position: sticky; top: 0; height: 100dvh;
        overflow-y: auto; padding: 16px 14px 30px; display: flex; flex-direction: column; gap: 14px;
      }
      .brand { font: 700 1.05rem/1.15 var(--font-display); letter-spacing: -0.01em; margin: 0; }
      .brandsub { color: var(--mut); font-size: 0.72rem; margin-top: 3px; }
      .side input[type="search"] {
        width: 100%; background: #fff; border: 1px solid var(--sand); color: var(--ink);
        padding: 8px 10px; border-radius: var(--radius); font: inherit; font-size: 0.85rem;
      }
      .side input:focus-visible, .side select:focus-visible, .navrow:focus-visible, button:focus-visible { outline: 2px solid var(--blue); outline-offset: 1px; }
      .grouplabel { font-family: var(--font-mono); font-size: 0.64rem; text-transform: uppercase; letter-spacing: 0.09em; color: var(--mut); margin: 2px 2px 4px; }
      .navlist { display: flex; flex-direction: column; gap: 1px; }
      .navrow {
        display: flex; align-items: center; gap: 8px; width: 100%; text-align: left; cursor: pointer;
        border: 0; background: none; font: inherit; font-size: 0.83rem; color: var(--ink);
        padding: 6px 8px; border-radius: 6px; transition: background var(--t);
      }
      .navrow:hover { background: #fff; }
      .navrow.on { background: #fff; font-weight: 600; box-shadow: inset 2px 0 0 var(--ink); }
      .navrow .dot { width: 9px; height: 9px; border-radius: 50%; flex: none; }
      .navrow .n { margin-left: auto; color: var(--mut); font-family: var(--font-mono); font-size: 0.72rem; }
      .toggles { display: flex; flex-direction: column; gap: 6px; }
      .chk { display: flex; align-items: center; gap: 8px; font-size: 0.8rem; color: var(--ink); cursor: pointer; padding: 3px 2px; }
      .side select { width: 100%; background: #fff; border: 1px solid var(--sand); color: var(--ink); padding: 7px 9px; border-radius: var(--radius); font: inherit; font-size: 0.82rem; }
      .side .graphbtn { margin-top: 2px; }
      .graphbtn { width: 100%; border: 1px solid var(--sand); background: #fff; color: var(--ink); font: inherit; font-size: 0.82rem; padding: 8px; border-radius: var(--radius); cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 7px; }
      .graphbtn:hover { border-color: var(--mut); }
      .graphbtn.on { background: var(--ink); color: var(--paper); border-color: var(--ink); }

      /* ── Main / list ────────────────────────────────── */
      main { flex: 1; min-width: 0; }
      .wrap { max-width: 860px; margin: 0 auto; padding: 20px 26px 70px; }
      .count { color: var(--mut); font-size: 0.76rem; margin: 4px 2px 12px; font-family: var(--font-mono); }
      .mobilebar { display: none; }
      .card {
        background: var(--ivory); border: 1px solid var(--sand); border-radius: var(--radius);
        padding: 13px 15px; margin: 9px 0; cursor: pointer; transition: border-color var(--t), transform var(--t);
      }
      .card:hover { border-color: var(--mut); transform: translateY(-1px); }
      .card.hr { border-left: 3px solid var(--amber); }
      .ct { font-weight: 600; font-size: 0.98rem; line-height: 1.35; }
      .cs { color: var(--mut); font-size: 0.82rem; margin-top: 3px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
      .tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px; align-items: center; }
      .tag { font-size: 0.68rem; color: var(--mut); background: var(--paper); border: 1px solid var(--sand); padding: 1px 8px; border-radius: 5px; font-family: var(--font-mono); display: inline-flex; align-items: center; gap: 5px; }
      .tag.warn { color: #7a5800; border-color: #e3cf96; background: #faf3df; }
      .empty { text-align: center; color: var(--mut); padding: 70px 0; }

      /* ── Reader ─────────────────────────────────────── */
      .reader { max-width: 760px; margin: 0 auto; padding: 22px 26px 80px; }
      .crumbs { font-family: var(--font-mono); font-size: 0.72rem; color: var(--mut); margin-bottom: 14px; display: flex; gap: 7px; flex-wrap: wrap; align-items: center; }
      .crumbs a { color: var(--mut); text-decoration: none; }
      .crumbs a:hover { color: var(--ink); text-decoration: underline; }
      .reader h2 { font: 700 1.7rem/1.2 var(--font-display); margin: 4px 0 6px; letter-spacing: -0.01em; }
      .slugline { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; color: var(--mut); font-size: 0.75rem; font-family: var(--font-mono); margin-bottom: 10px; }
      .slugline code { background: var(--ivory); border: 1px solid var(--sand); padding: 2px 7px; border-radius: 5px; }
      .slugline button { border: 1px solid var(--sand); background: var(--ivory); color: var(--mut); border-radius: 5px; font: inherit; font-size: 0.7rem; padding: 2px 8px; cursor: pointer; }
      .slugline button:hover { color: var(--ink); border-color: var(--mut); }
      dl { margin: 18px 0 0; }
      dt { color: var(--mut); font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.07em; margin-top: 16px; font-weight: 600; }
      dd { margin: 4px 0 0; white-space: pre-wrap; word-break: break-word; font-size: 0.9rem; line-height: 1.6; }
      dd.mono { font-family: var(--font-mono); font-size: 0.78rem; background: var(--ivory); border: 1px solid var(--sand); border-radius: var(--radius); padding: 9px 11px; white-space: pre-wrap; }
      .connsec { margin-top: 22px; border-top: 1px solid var(--sand); padding-top: 16px; }
      .connsec > dt { margin-top: 14px; }
      .connlist { display: flex; flex-direction: column; gap: 6px; margin-top: 6px; }
      .connlist button {
        text-align: left; border: 1px solid var(--sand); background: var(--ivory); border-radius: var(--radius);
        padding: 7px 11px; font: inherit; font-size: 0.83rem; cursor: pointer; display: flex; align-items: center; gap: 8px; color: var(--ink);
      }
      .connlist button:hover { border-color: var(--mut); }
      .unres { color: var(--mut); font-size: 0.8rem; margin-top: 6px; line-height: 1.5; }
      .unres span { border-bottom: 1px dotted var(--rule); }
      .prevnext { display: flex; justify-content: space-between; gap: 12px; margin-top: 30px; border-top: 1px solid var(--sand); padding-top: 16px; }
      .prevnext button { flex: 1 1 0; min-width: 0; border: 1px solid var(--sand); background: var(--ivory); border-radius: var(--radius); padding: 10px 13px; font: inherit; cursor: pointer; color: var(--ink); }
      .prevnext button:hover:not(:disabled) { border-color: var(--mut); }
      .prevnext button:disabled { opacity: 0.4; cursor: default; }
      .prevnext .pn-k { font-family: var(--font-mono); font-size: 0.66rem; color: var(--mut); text-transform: uppercase; letter-spacing: 0.06em; }
      .prevnext .pn-t { font-size: 0.85rem; margin-top: 3px; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
      .prevnext .nx { text-align: right; }
      .dot { width: 9px; height: 9px; border-radius: 50%; flex: none; display: inline-block; }
      .kbd { border: 1px solid var(--sand); border-bottom-width: 2px; border-radius: 4px; background: var(--ivory); padding: 0 5px; font-family: var(--font-mono); font-size: 0.68rem; }

      /* ── Graph ──────────────────────────────────────── */
      #graphwrap { display: none; position: relative; }
      #graphwrap.on { display: block; }
      #gcanvas { display: block; width: 100%; cursor: grab; }
      #tip { position: fixed; display: none; z-index: 30; pointer-events: none; max-width: 300px; background: #fff; border: 1px solid var(--sand); border-radius: var(--radius); box-shadow: 0 4px 18px rgba(29,26,22,0.12); padding: 8px 11px; font-size: 0.8rem; }
      #tip .t { font-weight: 600; }
      #tip .m { color: var(--mut); font-size: 0.72rem; margin-top: 2px; display: flex; align-items: center; gap: 5px; }
      .gleg { position: absolute; left: 12px; bottom: 12px; background: rgba(251,249,243,0.92); border: 1px solid var(--sand); border-radius: var(--radius); padding: 8px 11px; font-size: 0.7rem; color: var(--mut); }

      @media (max-width: 860px) {
        aside.side { position: fixed; left: 0; top: 0; z-index: 40; transform: translateX(-100%); transition: transform var(--t); box-shadow: 0 0 40px rgba(29,26,22,0.18); }
        aside.side.open { transform: none; }
        .mobilebar { display: flex; align-items: center; gap: 10px; position: sticky; top: 0; z-index: 20; background: var(--paper); border-bottom: 1px solid var(--sand); padding: 10px 14px; }
        .mobilebar button { border: 1px solid var(--sand); background: var(--ivory); border-radius: 6px; padding: 6px 10px; font: inherit; cursor: pointer; }
        .wrap, .reader { padding: 14px 16px 60px; }
        .gleg { display: none; }
      }
    </style>
  </head>

  <body>
    {INTERNAL ? (
      <>
    <div class="app">
      <aside class="side" id="side">
        <div>
          <p class="brand">Knowledge Commons</p>
          <p class="brandsub">Internal review · <b>{objects.length}</b> objects · <b>{rawCount}</b> in queue · <b>{highRisk}</b> high-risk</p>
        </div>
        <input id="q" type="search" placeholder="Search title, summary, slug…" autocomplete="off" />
        <div>
          <p class="grouplabel">Type</p>
          <div class="navlist" id="schemaNav">
            <button class="navrow on" data-f="all"><span>All objects</span><span class="n">{objects.length}</span></button>
            {schemas.map((s) => (
              <button class="navrow" data-f={s}><span class="dot" style={`background:${COLORS[s]}`}></span><span>{s}</span><span class="n">{bySchema[s]}</span></button>
            ))}
          </div>
        </div>
        <div>
          <p class="grouplabel">Domain</p>
          <select id="dom" aria-label="Filter by domain">
            <option value="">all domains</option>
            {domains.map((d) => <option>{d}</option>)}
          </select>
        </div>
        <div class="toggles">
          <p class="grouplabel">Filter</p>
          <label class="chk"><input type="checkbox" id="hrOnly" /> ⚠ high-risk only</label>
          <label class="chk"><input type="checkbox" id="rawOnly" /> raw (in review) only</label>
        </div>
        <div>
          <p class="grouplabel">Sort</p>
          <select id="sort" aria-label="Sort">
            <option value="title">title</option>
            <option value="schema">schema</option>
            <option value="domain">domain</option>
            <option value="risk">high-risk first</option>
            <option value="connections">most connected</option>
          </select>
        </div>
        <button class="graphbtn" id="graphToggle">◱ Graph view</button>
        <p class="brandsub" style="margin-top:auto"><span class="kbd">/</span> search · <span class="kbd">g</span> graph · <span class="kbd">[</span> <span class="kbd">]</span> prev/next · <span class="kbd">esc</span> back</p>
      </aside>

      <main>
        <div class="mobilebar">
          <button id="menuBtn" aria-label="Menu">☰</button>
          <strong style="font-family:var(--font-display)">Knowledge Commons</strong>
        </div>

        <div id="browse">
          <div class="wrap">
            <div class="count" id="count"></div>
            <div id="list"></div>
          </div>
        </div>

        <div id="graphwrap">
          <canvas id="gcanvas"></canvas>
          <div class="gleg">node = object · color = schema · size = connections · ⚠ amber ring = high-risk · edges = same source / shared concepts · drag to pan · scroll to zoom · click to open</div>
        </div>

        <div id="readerwrap" style="display:none"><article class="reader" id="reader"></article></div>
      </main>
    </div>

    <div id="tip"></div>

    <script is:inline set:html={`window.KB=${inlineJson(objects)};window.GRAPH=${inlineJson(graph)};window.CONN=${inlineJson(conn)};window.COLORS=${inlineJson(COLORS)};window.INFO=${inlineJson(TYPE_INFO)};`}></script>
    <script is:inline>
      (function () {
        "use strict";
        var KB = window.KB, GRAPH = window.GRAPH, CONN = window.CONN, COLORS = window.COLORS;
        var $ = function (id) { return document.getElementById(id); };
        var listEl = $("list"), countEl = $("count"), tip = $("tip"), reader = $("reader"), side = $("side");
        var esc = function (s) { return String(s).replace(/[&<>"]/g, function (c) { return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]; }); };

        // (schema/slug) -> index, and adjacency for the graph.
        var byId = {}; KB.forEach(function (o, i) { byId[o.schema + "/" + o.slug] = i; });
        var adj = KB.map(function () { return []; });
        GRAPH.links.forEach(function (l) { adj[l[0]].push(l[1]); adj[l[1]].push(l[0]); });
        var connCount = KB.map(function (_, i) { return CONN.out[i].length + CONN.backlinks[i].length + CONN.siblings[i].length; });

        // Typed field order per schema; the rest render generically after.
        var FIELD_ORDER = {
          "claim-evidence": ["claim", "evidence", "interpretation", "uncertainty"],
          "concept-lineage": ["short_description", "source_traditions", "tensions", "risks_of_flattening", "toolkit_usage"],
          "signal": ["interpretation", "proposed_intervention", "signal_type"],
          "encyclopedia-entry": ["summary", "known_tensions", "audience", "page_type"],
          "resource": ["summary", "notes", "resource_type", "link_status"],
          "source-system": ["what_it_curates", "url", "update_rhythm"],
          "public-use-boundary": ["consent_note", "tier", "review_type"],
        };
        var LABELS = {
          short_description: "description", proposed_intervention: "proposed intervention",
          known_tensions: "known tensions", risks_of_flattening: "risks of flattening",
          source_traditions: "source traditions", toolkit_usage: "toolkit usage",
          resource_type: "type", signal_type: "type", page_type: "type",
          link_status: "link status", update_rhythm: "update rhythm", review_type: "review type",
          what_it_curates: "what it curates", work_order: "work order",
        };
        var lbl = function (k) { return LABELS[k] || k.replace(/_/g, " "); };

        var state = { F: "all", HR: false, RAW: false, Q: "", D: "", S: "title" };

        function tagRow(o) {
          return '<div class="tags">' +
            '<span class="tag"><span class="dot" style="background:' + COLORS[o.schema] + '"></span>' + o.schema + "</span>" +
            (o.subtype && o.subtype !== o.schema ? '<span class="tag">' + esc(o.subtype) + "</span>" : "") +
            (o.domain ? '<span class="tag">' + esc(o.domain) + "</span>" : "") +
            '<span class="tag">' + esc(o.maturity) + "</span>" +
            (o.high_risk ? '<span class="tag warn">⚠ high-risk</span>' : "") + "</div>";
        }

        function filtered() {
          var q = state.Q.toLowerCase(), out = [];
          for (var i = 0; i < KB.length; i++) {
            var o = KB[i];
            if (state.F !== "all" && o.schema !== state.F) continue;
            if (state.HR && !o.high_risk) continue;
            if (state.RAW && o.maturity !== "raw") continue;
            if (state.D && o.domain !== state.D) continue;
            if (q && (o.title + " " + o.summary + " " + o.slug).toLowerCase().indexOf(q) === -1) continue;
            out.push(i);
          }
          var cmp = {
            title: function (a, b) { return KB[a].title.localeCompare(KB[b].title); },
            schema: function (a, b) { return KB[a].schema.localeCompare(KB[b].schema) || KB[a].title.localeCompare(KB[b].title); },
            domain: function (a, b) { return (KB[a].domain || "￿").localeCompare(KB[b].domain || "￿") || KB[a].title.localeCompare(KB[b].title); },
            risk: function (a, b) { return (KB[b].high_risk - KB[a].high_risk) || KB[a].title.localeCompare(KB[b].title); },
            connections: function (a, b) { return connCount[b] - connCount[a] || KB[a].title.localeCompare(KB[b].title); },
          }[state.S];
          out.sort(cmp);
          return out;
        }
        var curList = [];

        function renderList() {
          curList = filtered();
          countEl.textContent = curList.length + " / " + KB.length + " objects";
          if (!curList.length) { listEl.innerHTML = '<div class="empty">No objects match. Clear a filter or the search.</div>'; return; }
          listEl.innerHTML = curList.map(function (i) {
            var o = KB[i];
            return '<article class="card' + (o.high_risk ? " hr" : "") + '" data-i="' + i + '"><div class="ct">' + esc(o.title) + "</div>" +
              (o.summary ? '<div class="cs">' + esc(o.summary) + "</div>" : "") + tagRow(o) + "</article>";
          }).join("");
        }
        listEl.addEventListener("click", function (e) {
          var card = e.target.closest(".card"); if (card) go("#/o/" + KB[+card.dataset.i].schema + "/" + KB[+card.dataset.i].slug);
        });

        /* ── Reader ── */
        function fieldHtml(k, v, mono) {
          if (v == null || v === "" || (Array.isArray(v) && !v.length)) return "";
          var body = Array.isArray(v)
            ? v.map(function (x) { return typeof x === "object" ? JSON.stringify(x, null, 2) : String(x); }).join("\n")
            : typeof v === "object" ? JSON.stringify(v, null, 2) : String(v);
          return "<dt>" + esc(lbl(k)) + '</dt><dd class="' + (mono ? "mono" : "") + '">' + esc(body) + "</dd>";
        }
        function connBtns(idxs) {
          return idxs.map(function (j) {
            var c = KB[j];
            return '<button data-go="' + c.schema + "/" + c.slug + '"><span class="dot" style="background:' + COLORS[c.schema] + '"></span>' + esc(c.title) + (c.high_risk ? " ⚠" : "") + "</button>";
          }).join("");
        }
        function renderReader(i) {
          var o = KB[i], r = o.raw;
          var order = FIELD_ORDER[o.schema] || ["summary"];
          var shown = { title: 1, provenance: 1, related_concepts: 1, type: 1 };
          var primary = "";
          order.forEach(function (k) { if (r[k] != null && r[k] !== "") { primary += fieldHtml(k, r[k], false); shown[k] = 1; } });
          var rest = Object.keys(r).filter(function (k) { return !shown[k]; })
            .map(function (k) { return fieldHtml(k, r[k], typeof r[k] === "object"); }).join("");
          var prov = r.provenance ? fieldHtml("provenance", r.provenance, true) : "";

          var refs = CONN.out[i], backs = CONN.backlinks[i], sibs = CONN.siblings[i], unres = CONN.unresolved[i];
          var connHtml = "";
          if (refs.length) connHtml += "<dt>References (" + refs.length + ")</dt><div class='connlist'>" + connBtns(refs) + "</div>";
          if (backs.length) connHtml += "<dt>Referenced by (" + backs.length + ")</dt><div class='connlist'>" + connBtns(backs) + "</div>";
          if (sibs.length) connHtml += "<dt>Same source (" + sibs.length + ")</dt><div class='connlist'>" + connBtns(sibs.slice(0, 20)) + "</div>";
          if (unres.length) connHtml += "<dt>Unresolved concepts</dt><div class='unres'>" + unres.map(function (u) { return "<span>" + esc(u) + "</span>"; }).join(" · ") + "</div>";

          var pos = curList.indexOf(i);
          var prev = pos > 0 ? curList[pos - 1] : -1, next = pos >= 0 && pos < curList.length - 1 ? curList[pos + 1] : -1;
          var pnBtn = function (j, dir) {
            if (j < 0) return '<button disabled><span class="pn-k">' + dir + "</span></button>";
            var c = KB[j], cls = dir === "Next →" ? " nx" : "";
            return '<button data-go="' + c.schema + "/" + c.slug + '" class="' + cls + '"><span class="pn-k">' + dir + '</span><span class="pn-t">' + esc(c.title) + "</span></button>";
          };

          reader.innerHTML =
            '<div class="crumbs"><a href="#/" data-nav>Commons</a> / <a href="#/" data-schema="' + o.schema + '">' + o.schema + "</a> / <span>" + esc(o.slug) + "</span></div>" +
            "<h2>" + esc(o.title) + "</h2>" +
            '<div class="slugline"><code>' + esc(o.id) + "</code>" +
            '<button id="copylink">copy link</button>' +
            (o.origin ? '<a href="' + esc(o.origin) + '" target="_blank" rel="noreferrer">source ↗</a>' : "") + "</div>" +
            tagRow(o) +
            "<dl>" + primary + prov + rest + "</dl>" +
            (connHtml ? '<div class="connsec">' + connHtml + "</div>" : "") +
            '<div class="prevnext">' + pnBtn(prev, "← Prev") + pnBtn(next, "Next →") + "</div>";

          $("copylink").onclick = function () {
            navigator.clipboard.writeText(location.href);
            this.textContent = "copied ✓"; var b = this; setTimeout(function () { b.textContent = "copy link"; }, 1200);
          };
          reader.querySelectorAll("[data-go]").forEach(function (b) { b.onclick = function () { go("#/o/" + b.dataset.go); }; });
          reader.querySelectorAll("[data-schema]").forEach(function (b) { b.onclick = function (e) { e.preventDefault(); setSchema(b.dataset.schema); go("#/"); }; });
          window.scrollTo(0, 0);
        }

        /* ── Graph engine (hand-rolled; self-containment > d3) ── */
        var canvas = $("gcanvas"), ctx = canvas.getContext("2d");
        var sim = null, raf = 0, T = { x: 0, y: 0, k: 1 }, hoverN = -1, fitted = false;
        function buildSim(vis) {
          var setV = {}; vis.forEach(function (i, s) { setV[i] = s; });
          var n = vis.length, R = Math.sqrt(n) * 26 + 40;
          var nodes = vis.map(function (i, s) {
            var a = (s / n) * Math.PI * 2, rr = R * (0.35 + 0.65 * Math.sqrt((s % 97) / 97));
            var g = GRAPH.nodes[i];
            return { i: i, x: Math.cos(a) * rr, y: Math.sin(a) * rr, vx: 0, vy: 0, r: 3 + 2 * Math.sqrt(g.degree), c: COLORS[g.schema], hr: g.hr };
          });
          var links = [];
          GRAPH.links.forEach(function (l) { if (setV[l[0]] !== undefined && setV[l[1]] !== undefined) links.push([setV[l[0]], setV[l[1]]]); });
          sim = { nodes: nodes, links: links, alpha: 1 }; fitted = false;
        }
        function tick() {
          var N = sim.nodes, L = sim.links, i, j, a, b, dx, dy, d2, d, f;
          for (i = 0; i < N.length; i++) for (j = i + 1; j < N.length; j++) {
            a = N[i]; b = N[j]; dx = b.x - a.x; dy = b.y - a.y;
            d2 = dx * dx + dy * dy; if (d2 < 1) d2 = 1; if (d2 > 48400) continue;
            f = 320 / d2; d = Math.sqrt(d2); dx /= d; dy /= d;
            a.vx -= dx * f; a.vy -= dy * f; b.vx += dx * f; b.vy += dy * f;
          }
          for (i = 0; i < L.length; i++) {
            a = N[L[i][0]]; b = N[L[i][1]];
            dx = b.x - a.x; dy = b.y - a.y; d = Math.sqrt(dx * dx + dy * dy) || 1;
            f = (d - 40) * 0.06 / d; a.vx += dx * f; a.vy += dy * f; b.vx -= dx * f; b.vy -= dy * f;
          }
          for (i = 0; i < N.length; i++) {
            a = N[i]; a.vx -= a.x * 0.005; a.vy -= a.y * 0.005; a.vx *= 0.82; a.vy *= 0.82;
            a.x += Math.max(-14, Math.min(14, a.vx)) * sim.alpha; a.y += Math.max(-14, Math.min(14, a.vy)) * sim.alpha;
          }
          sim.alpha *= 0.995;
        }
        function fit() {
          var N = sim.nodes; if (!N.length) return;
          var x0 = 1e9, y0 = 1e9, x1 = -1e9, y1 = -1e9;
          N.forEach(function (n) { x0 = Math.min(x0, n.x); x1 = Math.max(x1, n.x); y0 = Math.min(y0, n.y); y1 = Math.max(y1, n.y); });
          var w = canvas.clientWidth, h = canvas.clientHeight;
          var k = Math.min(2, 0.9 * Math.min(w / Math.max(1, x1 - x0), h / Math.max(1, y1 - y0)));
          T.k = k; T.x = w / 2 - k * (x0 + x1) / 2; T.y = h / 2 - k * (y0 + y1) / 2;
        }
        function draw() {
          var dpr = window.devicePixelRatio || 1, w = canvas.clientWidth, h = canvas.clientHeight;
          if (canvas.width !== w * dpr || canvas.height !== h * dpr) { canvas.width = w * dpr; canvas.height = h * dpr; }
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0); ctx.clearRect(0, 0, w, h);
          ctx.translate(T.x, T.y); ctx.scale(T.k, T.k);
          var N = sim.nodes, L = sim.links, i;
          ctx.strokeStyle = "rgba(107,102,96,0.28)"; ctx.lineWidth = 1 / T.k; ctx.beginPath();
          for (i = 0; i < L.length; i++) { var a = N[L[i][0]], b = N[L[i][1]]; ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); }
          ctx.stroke();
          for (i = 0; i < N.length; i++) {
            var n = N[i];
            if (n.hr) { ctx.beginPath(); ctx.arc(n.x, n.y, n.r + 3 / T.k, 0, 6.2832); ctx.strokeStyle = "#B08000"; ctx.lineWidth = 1.8 / T.k; ctx.stroke(); }
            ctx.beginPath(); ctx.arc(n.x, n.y, n.r, 0, 6.2832); ctx.fillStyle = n.c; ctx.fill();
            ctx.strokeStyle = "#fbf9f3"; ctx.lineWidth = Math.min(2, 2 / T.k); ctx.stroke();
            if (i === hoverN) { ctx.beginPath(); ctx.arc(n.x, n.y, n.r + 1.5 / T.k, 0, 6.2832); ctx.strokeStyle = "#1d1a16"; ctx.lineWidth = 1.5 / T.k; ctx.stroke(); }
          }
        }
        function loop() {
          if (sim.alpha > 0.015) { tick(); tick(); } else if (!fitted) { fit(); fitted = true; }
          draw(); raf = requestAnimationFrame(loop);
        }
        function sizeCanvas() { var top = 0; canvas.style.height = "calc(100dvh - " + (top + 2) + "px)"; }
        var drag = null, moved = 0;
        canvas.addEventListener("pointerdown", function (e) { drag = { x: e.clientX, y: e.clientY, tx: T.x, ty: T.y }; moved = 0; canvas.style.cursor = "grabbing"; canvas.setPointerCapture(e.pointerId); });
        canvas.addEventListener("pointerup", function (e) {
          canvas.style.cursor = "grab"; canvas.releasePointerCapture(e.pointerId);
          if (drag && moved < 4 && hoverN >= 0) go("#/o/" + KB[sim.nodes[hoverN].i].schema + "/" + KB[sim.nodes[hoverN].i].slug);
          drag = null;
        });
        canvas.addEventListener("pointermove", function (e) {
          if (drag) { moved += Math.abs(e.movementX) + Math.abs(e.movementY); T.x = drag.tx + (e.clientX - drag.x); T.y = drag.ty + (e.clientY - drag.y); return; }
          var rect = canvas.getBoundingClientRect();
          var wx = (e.clientX - rect.left - T.x) / T.k, wy = (e.clientY - rect.top - T.y) / T.k;
          var best = -1, bd = 1e9, N = sim ? sim.nodes : [];
          for (var i = 0; i < N.length; i++) { var dx = N[i].x - wx, dy = N[i].y - wy, dd = dx * dx + dy * dy, rr = N[i].r + 5 / T.k; if (dd < rr * rr && dd < bd) { bd = dd; best = i; } }
          hoverN = best;
          if (best >= 0) {
            var o = KB[N[best].i];
            tip.innerHTML = '<div class="t">' + esc(o.title) + '</div><div class="m"><span class="dot" style="background:' + COLORS[o.schema] + '"></span>' + o.schema + (o.high_risk ? " · ⚠ high-risk" : "") + "</div>";
            tip.style.display = "block"; tip.style.left = Math.min(window.innerWidth - 310, e.clientX + 14) + "px"; tip.style.top = (e.clientY + 14) + "px"; canvas.style.cursor = "pointer";
          } else { tip.style.display = "none"; canvas.style.cursor = "grab"; }
        });
        canvas.addEventListener("pointerleave", function () { tip.style.display = "none"; hoverN = -1; });
        canvas.addEventListener("wheel", function (e) {
          e.preventDefault();
          var rect = canvas.getBoundingClientRect(), mx = e.clientX - rect.left, my = e.clientY - rect.top;
          var k2 = Math.max(0.35, Math.min(4, T.k * Math.exp(-e.deltaY * 0.0012)));
          T.x = mx - (mx - T.x) * (k2 / T.k); T.y = my - (my - T.y) * (k2 / T.k); T.k = k2;
        }, { passive: false });

        /* ── Router ── */
        function show(which) {
          $("browse").style.display = which === "browse" ? "" : "none";
          $("readerwrap").style.display = which === "reader" ? "" : "none";
          $("graphwrap").classList.toggle("on", which === "graph");
          $("graphToggle").classList.toggle("on", which === "graph");
          if (which === "graph") { sizeCanvas(); buildSim(filtered()); if (!raf) loop(); }
          else { cancelAnimationFrame(raf); raf = 0; }
        }
        function go(hash) { if (location.hash === hash) route(); else location.hash = hash; }
        function route() {
          var h = location.hash || "#/";
          if (side) side.classList.remove("open");
          if (h.indexOf("#/o/") === 0) {
            var id = decodeURIComponent(h.slice(4));
            var i = byId[id];
            if (i === undefined) { go("#/"); return; }
            if (!curList.length) renderList();
            renderReader(i); show("reader"); return;
          }
          if (h === "#/graph") { renderList(); show("graph"); return; }
          renderList(); show("browse");
        }
        window.addEventListener("hashchange", route);

        /* ── Controls ── */
        function setSchema(f) {
          state.F = f;
          document.querySelectorAll("#schemaNav .navrow").forEach(function (x) { x.classList.toggle("on", x.dataset.f === f); });
        }
        document.querySelectorAll("#schemaNav .navrow").forEach(function (btn) {
          btn.onclick = function () { setSchema(btn.dataset.f); if (location.hash.indexOf("#/o/") === 0) go("#/"); else route(); };
        });
        $("q").oninput = function (e) { state.Q = e.target.value; if (location.hash.indexOf("#/o/") === 0) go("#/"); else route(); };
        $("dom").onchange = function (e) { state.D = e.target.value; route(); };
        $("sort").onchange = function (e) { state.S = e.target.value; route(); };
        $("hrOnly").onchange = function (e) { state.HR = e.target.checked; route(); };
        $("rawOnly").onchange = function (e) { state.RAW = e.target.checked; route(); };
        $("graphToggle").onclick = function () { go(location.hash === "#/graph" ? "#/" : "#/graph"); };
        $("menuBtn").onclick = function () { side.classList.toggle("open"); };
        window.addEventListener("resize", function () { if (location.hash === "#/graph") sizeCanvas(); });

        document.addEventListener("keydown", function (e) {
          var typing = /INPUT|SELECT|TEXTAREA/.test(document.activeElement.tagName);
          if (e.key === "Escape") { if (location.hash.indexOf("#/o/") === 0 || location.hash === "#/graph") go("#/"); return; }
          if (typing) return;
          if (e.key === "/") { e.preventDefault(); $("q").focus(); }
          if (e.key === "g") { e.preventDefault(); go(location.hash === "#/graph" ? "#/" : "#/graph"); }
          if ((e.key === "[" || e.key === "]") && location.hash.indexOf("#/o/") === 0) {
            var cur = byId[decodeURIComponent(location.hash.slice(4))], pos = curList.indexOf(cur);
            if (e.key === "[" && pos > 0) go("#/o/" + KB[curList[pos - 1]].schema + "/" + KB[curList[pos - 1]].slug);
            if (e.key === "]" && pos >= 0 && pos < curList.length - 1) go("#/o/" + KB[curList[pos + 1]].schema + "/" + KB[curList[pos + 1]].slug);
          }
        });

        route();
      })();
    </script>
      </>
    ) : (
      <main style="max-width:560px;margin:18vh auto;padding:0 20px;text-align:center">
        <h1 style="font-family:var(--font-display)">Internal review instance</h1>
        <p style="color:#6b6660">
          The knowledge-commons review surface is password-gated and lives at
          <a href="https://refibcn.github.io/commons-review/">refibcn.github.io/commons-review</a>.
          Ask the ReFi BCN team for access.
        </p>
      </main>
    )}
  </body>
</html>
