---
// ProcessStrip.astro — how an engagement runs. Numbered editorial steps
// (mono indices, 1px-ink top rules). Data from src/data/process.yaml.
import fs from "node:fs";
import path from "node:path";
import yaml from "js-yaml";

interface Step { title: string; body: string; }
const steps = (yaml.load(
  fs.readFileSync(path.join(process.cwd(), "src/data/process.yaml"), "utf8")
) as { steps: Step[] }).steps;

interface Props { title?: string; }
const { title = "How an engagement runs" } = Astro.props;
---
<section class="process">
  <p class="eyebrow">{title}</p>
  <ol class="process__steps">
    {steps.map((s, i) => (
      <li class="step">
        <span class="step__index">{String(i + 1).padStart(2, "0")}</span>
        <h3 class="step__title">{s.title}</h3>
        <p class="step__body">{s.body}</p>
      </li>
    ))}
  </ol>
</section>

<style>
.process { margin-top: var(--space-12); }
.process__steps {
  list-style: none;
  margin: var(--space-5) 0 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
  gap: var(--space-6);
}
.step {
  border-top: 1px solid var(--ink, var(--text-primary));
  padding-top: var(--space-4);
}
.step__index {
  font-family: var(--mono);
  font-size: var(--text-sm);
  color: var(--primary);
}
.step__title { font-size: var(--text-md); margin: var(--space-2) 0; }
.step__body {
  color: var(--text-muted);
  font-size: var(--text-sm);
  line-height: var(--leading-body);
  margin: 0;
}
</style>
