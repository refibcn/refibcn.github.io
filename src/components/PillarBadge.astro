---
// PillarBadge.astro — the three-capability pillar badge (Andrea's landing).
//   tissue → Network coordination · neural → Collective intelligence · flow → Regenerative finance
interface Props { pillar: "tissue" | "neural" | "flow"; label?: string; }
const { pillar, label } = Astro.props;
const defaults = { tissue: "Network coordination", neural: "Collective intelligence", flow: "Regenerative finance" };
---
<span class={`pillar-badge pillar-badge--${pillar}`}>{label ?? defaults[pillar]}</span>
<style>
.pillar-badge {
  display: inline-flex; align-items: center; gap: 0.45em;
  font-family: var(--mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.07em;
  padding: 0.3em 0.7em; border: 1px solid; border-radius: var(--radius-pill); white-space: nowrap;
}
.pillar-badge::before { content: ""; width: 0.5em; height: 0.5em; border-radius: 50%; background: currentColor; flex: none; }
.pillar-badge--tissue { color: var(--pillar-tissue-dark); border-color: color-mix(in srgb, var(--pillar-tissue-mid) 55%, transparent); background: color-mix(in srgb, var(--pillar-tissue-light) 45%, var(--paper)); }
.pillar-badge--neural { color: var(--pillar-neural-dark); border-color: color-mix(in srgb, var(--pillar-neural-mid) 55%, transparent); background: color-mix(in srgb, var(--pillar-neural-light) 45%, var(--paper)); }
.pillar-badge--flow   { color: var(--pillar-flow-dark);   border-color: color-mix(in srgb, var(--pillar-flow-mid) 55%, transparent);   background: color-mix(in srgb, var(--pillar-flow-light) 45%, var(--paper)); }
</style>
