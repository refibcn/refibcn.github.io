---
interface Props {
  title: string;
  body: string;
  href?: string;
}
const { title, body, href = "#" } = Astro.props;
---

<article class="card">
  <div class="card__body">
    <h3 class="card__title">{title}</h3>
    <p class="card__text">{body}</p>
    <a class="card__action" href={href}>Learn more →</a>
  </div>
</article>
