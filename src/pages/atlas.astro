---
import Layout from "../components/Layout.astro";
import SectionBlock from "../components/SectionBlock.astro";
---
<Layout title="Atlas" current="atlas" section="Bioregional Commons" dataset="Catalunya"
  description="A living atlas of Catalunya's regenerative territory — actors, cohorts, and bioregional-health signals.">
  <SectionBlock id="atlas" title="Atlas" intro="A living atlas of Catalunya's regenerative territory — actors, project cohorts, and bioregional-health signals, made legible to a public audience." tissue={true} tissueSeed={1}>
    <p class="lede">The territorial maps are being folded in from the Bioregional Intelligence work. The first dataset — the Regenerant Catalunya cohort — is live on the standalone surface while we integrate it here.</p>
    <p><a class="btn btn--secondary" href="https://luizfernandosg.github.io/bioregional-intelligence/" target="_blank" rel="noopener">View the current maps ↗</a></p>
    <p><span class="badge badge--info">In development</span> &nbsp; Maps integration — next phase.</p>
  </SectionBlock>
</Layout>
