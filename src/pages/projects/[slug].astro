---
import fs from "node:fs";
import path from "node:path";
import yaml from "js-yaml";
import Layout from "../../components/Layout.astro";
import Tissue from "../../components/Tissue.astro";
import StatBand from "../../components/StatBand.astro";
import CTABand from "../../components/CTABand.astro";

interface Stat { value: string; label: string; }
interface Project {
  title: string; slug?: string; role?: string; theme?: string; locality?: string;
  body?: string; image?: string; external?: boolean; href?: string;
  links?: { label: string; url: string }[];
  stats?: Stat[];
}

export function getStaticPaths() {
  const file = path.join(process.cwd(), "src/data/projects.yaml");
  const data = yaml.load(fs.readFileSync(file, "utf8")) as { projects: Project[] };
  const internal = data.projects.filter((p) => p.slug && !p.external && p.slug !== "regenerant-catalunya");
  return internal.map((p, i) => ({
    params: { slug: p.slug! },
    props: {
      project: p,
      prev: i > 0 ? internal[i - 1] : null,
      next: i < internal.length - 1 ? internal[i + 1] : null,
    },
  }));
}

const { project, prev, next } = Astro.props as {
  project: Project; prev: Project | null; next: Project | null;
};
const paras = (project.body ?? "").split(/\n\s*\n/).map((s) => s.trim()).filter(Boolean);
---
<Layout title={project.title} current="projects" section="Bioregional Commons" description={`${project.title} — a ReFi BCN case study.`}>
  <article class="case">
    <header class="case__head">
      <div class="case__tissue-wrap"><Tissue seed={2} opacity={0.1} tone="--pillar-tissue-mid" /></div>
      <p class="eyebrow">Case study</p>
      <h1>{project.title}</h1>
      <dl class="case__meta">
        {project.role && (<><dt>Role</dt><dd>{project.role}</dd></>)}
        {project.theme && (<><dt>Theme</dt><dd>{project.theme}</dd></>)}
        {project.locality && (<><dt>Where</dt><dd>{project.locality}</dd></>)}
      </dl>
    </header>

    {project.stats && project.stats.length > 0 && (
      <div class="case__stats"><StatBand stats={project.stats} /></div>
    )}

    {project.image && <img class="case__image" src={project.image} alt="" />}

    <div class="case__body">
      {paras.map((p) => <p>{p}</p>)}
    </div>

    {project.links && project.links.length > 0 && (
      <p class="case__links">
        {project.links.map((l) => (
          <a class="btn btn--secondary" href={l.url} target="_blank" rel="noopener">{l.label} ↗</a>
        ))}
      </p>
    )}
  </article>

  {(prev || next) && (
    <nav class="case-nav" aria-label="More case studies">
      <div class="case-nav__inner">
        {prev
          ? <a class="case-nav__link case-nav__prev" href={`/projects/${prev.slug}/`}>
              <span class="case-nav__dir">← Previous</span>
              <span class="case-nav__name">{prev.title}</span>
            </a>
          : <span class="case-nav__spacer"></span>}
        <a class="case-nav__all" href="/projects/">All projects</a>
        {next
          ? <a class="case-nav__link case-nav__next" href={`/projects/${next.slug}/`}>
              <span class="case-nav__dir">Next →</span>
              <span class="case-nav__name">{next.title}</span>
            </a>
          : <span class="case-nav__spacer"></span>}
      </div>
    </nav>
  )}

  <CTABand />
</Layout>

<style>
  .case { max-width: var(--container-prose); margin: 0 auto; padding: var(--space-16) var(--gutter) var(--space-12); }
  .case__head { position: relative; isolation: isolate; margin-bottom: var(--space-8); }
  .case__tissue-wrap { position: absolute; inset: -2rem -2rem auto -2rem; height: 12rem; z-index: -1; overflow: hidden; }
  .case__meta { display: grid; grid-template-columns: max-content 1fr; gap: var(--space-1) var(--space-4); margin-top: var(--space-5); }
  .case__meta dt { font-family: var(--mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); align-self: center; }
  .case__meta dd { margin: 0; }
  .case__stats { margin-bottom: var(--space-8); }
  .case__image { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; margin-bottom: var(--space-8); }
  .case__body p { margin: 0 0 var(--space-5); line-height: var(--leading-body); max-width: var(--container-prose); }
  .case__links { display: flex; gap: var(--space-3); flex-wrap: wrap; }

  .case-nav { border-top: 1px solid var(--ink); padding: var(--space-8) var(--gutter); }
  .case-nav__inner { max-width: var(--container-default); margin: 0 auto; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: var(--space-6); }
  .case-nav__link { text-decoration: none; color: var(--text-primary); display: flex; flex-direction: column; gap: var(--space-1); }
  .case-nav__next { text-align: right; align-items: flex-end; }
  .case-nav__dir { font-family: var(--mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.08em; color: var(--primary); }
  .case-nav__name { font-family: var(--serif); font-size: var(--text-md); }
  .case-nav__link:hover .case-nav__name { text-decoration: underline; }
  .case-nav__all { font-family: var(--mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); text-decoration: none; white-space: nowrap; }
  .case-nav__all:hover { color: var(--text-primary); }
  .case-nav__spacer { display: block; }

  @media (max-width: 640px) {
    .case-nav__inner { grid-template-columns: 1fr; text-align: left; }
    .case-nav__next { text-align: left; align-items: flex-start; }
    .case-nav__all { order: 3; }
  }
</style>
